# ===== RU-MD backend configuration =====
# Copy this file to ".env" and adjust the values for your environment.

# Server
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed front-end origins (Vite dev server by default)
CORS_ORIGIN=http://localhost:5173

# Database engine: "mysql" (default, used in production on Hostinger / local XAMPP)
DB_CLIENT=mysql

# MySQL (XAMPP defaults: host 127.0.0.1, port 3306, user root, empty password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ruaa_healthcare

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES=7d

# Default admin account created by the seed script
ADMIN_EMAIL=admin@rumd.me
ADMIN_PASSWORD=Admin@12345
